# LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=react-agent-phase1

# LLM Provider
OPENAI_API_KEY=your-openai-api-key-here

# Agent configuration
WORKSPACE_DIR=/workspace

# Trust provider (local for Phase 1)
TRUST_PROVIDER=local

# AgentFacts HMAC signing secret
AGENT_FACTS_SECRET=change-me

# ─────────────────────────────────────────────────────────────────────
# Sprint 0 / V3-Dev-Tier — see docs/plan/frontend/SPRINT_0_RUNBOOK.md
# ─────────────────────────────────────────────────────────────────────

# CopilotKit Cloud public API key (frontend, safe to expose to browser).
# Sign up at https://cloud.copilotkit.ai/sign-up and generate a project key.
# Env-var name follows CopilotKit 2026 docs (older "NEXT_PUBLIC_COPILOT_API_KEY"
# is deprecated). Required by Spike A (S0.2.*) and Sprint 3 frontend.
NEXT_PUBLIC_CPK_PUBLIC_API_KEY=cpk_pub_xxxxxxxxxxxxxxxxxxxx

# Mem0 Cloud Hobby (backend only — must NOT be exposed to the browser).
# Sign up at https://app.mem0.ai and create a key at
# https://app.mem0.ai/dashboard/api-keys. Hobby tier: 10K adds + 1K
# retrievals / month. Required by Spike C (S0.4.1) and Sprint 3 memory adapter.
MEM0_API_KEY=m0-xxxxxxxxxxxxxxxxxxxx
MEM0_BASE_URL=https://api.mem0.ai

# WorkOS AuthKit (backend only — API key must NOT be exposed to the browser).
# Sign up at https://workos.com/dashboard/sign-up.
# Dashboard > API Keys for both values. Client ID is public; API key is secret.
# Required by Sprint 1 middleware auth (S1.2.1) and Sprint 3 frontend auth (S3.7.1).
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_COOKIE_PASSWORD=a-32+-character-secret-for-cookie-encryption
# AuthKit Next.js reads this name (not WORKOS_REDIRECT_URI). Must match the callback
# route and an allowlisted Redirect URI in the WorkOS dashboard. Include the port you
# actually use (e.g. 3001 if 3000 is taken).
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Langfuse Cloud Hobby (backend only — must NOT be exposed to the browser).
# Sign up at https://cloud.langfuse.com. Settings > API Keys > Create new.
# Hobby tier: 50K observations/month. Required by Sprint 1 composition (S1.1.2)
# and Sprint 2 telemetry adapter.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Architecture profile (v3 = dev-tier free substrates; v2 = paid V2-Frontier).
# Only read by composition roots: middleware/composition.py, frontend/lib/composition.ts,
# agent_ui_adapter/server.py. See docs/Architectures/FRONTEND_ARCHITECTURE.md §Rule C1.
ARCHITECTURE_PROFILE=v3

# Neon Postgres (Sprint 2 §S2.1.2 — see infra/dev-tier/README.md §Account
# setup checklist). Generate at https://console.neon.tech →
# Account Settings → API Keys. The TF_VAR_* sibling lets OpenTofu pick
# up the same value without us writing it into terraform.tfvars.
NEON_API_KEY=napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TF_VAR_neon_api_key=napi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEON_DATABASE_NAME=neondb

# Cloudflare (Sprint 2 §S2.1.3). Capture from https://dash.cloudflare.com:
#   * account_id  — right sidebar of any page
#   * zone_id     — overview page right column for your domain
#   * api_token   — My Profile → API Tokens → Create custom token with
#                   Pages:Edit + Zone WAF/DNS/Settings Edit scopes
CLOUDFLARE_DOMAIN=agentsexpress.net
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=cfat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TF_VAR_cloudflare_account_id=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TF_VAR_cloudflare_zone_id=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TF_VAR_cloudflare_api_token=cfat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
