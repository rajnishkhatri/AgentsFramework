{
  "name": "agent-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "V3-Dev-Tier Next.js 15 frontend for the ReAct agent. Implements the four-ring architecture: wire/ (Zod kernels), trust-view/ (read-only), ports/ (vendor-neutral interfaces), adapters/ (SDK isolation), translators/ (pure functions), transport/ (SSE), composition/ (single profile switch). See docs/Architectures/FRONTEND_ARCHITECTURE.md and docs/STYLE_GUIDE_FRONTEND.md.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:arch": "vitest run tests/architecture",
    "typecheck": "tsc --noEmit",
    "regen:wire-types": "openapi-typescript ../openapi.yaml -o lib/wire-types.ts",
    "check:wire-types": "openapi-typescript ../openapi.yaml -o /tmp/agent-wire-types.ts && diff -u lib/wire-types.ts /tmp/agent-wire-types.ts",
    "wire-schema-snapshot": "tsx scripts/snapshot_wire_schemas.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "check:csp": "tsx scripts/check_csp_strict.ts middleware.ts",
    "check:iframe": "tsx scripts/check_iframe_sandbox.ts",
    "check:composer": "tsx scripts/check_composer_keyboard.ts components/chat/Composer.tsx",
    "check:secrets-env": "tsx scripts/check_secrets_in_public_env.ts",
    "check:jwt-storage": "tsx scripts/check_jwt_storage.ts",
    "check:sprint-story": "tsx scripts/check_sprint_story.ts",
    "check:axe-a11y": "tsx scripts/check_axe_a11y.ts",
    "check:bundle-budget": "tsx scripts/check_bundle_budget.ts"
  },
  "dependencies": {
    "@copilotkit/react-core": "^1.56.3",
    "@copilotkit/react-ui": "^1.56.3",
    "@copilotkit/runtime": "^1.56.3",
    "@langchain/langgraph-sdk": "^1.8.9",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/js-yaml": "^4.0.9",
    "@workos-inc/authkit-nextjs": "^2.0.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.1",
    "next": "^15.0.3",
    "next-themes": "^0.4.3",
    "postcss": "^8.5.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-config-next": "^15.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.4",
    "ts-morph": "^24.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
